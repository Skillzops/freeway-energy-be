model Device {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  serialNumber        String  @unique
  key                 String
  startingCode        String?
  count               String?
  timeDivider         String?
  restrictedDigitMode Boolean @default(false)
  hardwareModel       String?
  firmwareVersion     String?

  tokens Tokens[]

  isTokenable Boolean @default(false)

  isUsed Boolean @default(false)

  installationStatus    InstallationStatus @default(not_installed)
  installationLocation  String?
  installationLongitude String?
  installationLatitude  String?

  tokenFailures TokenGenerationFailure[]

  isAssigned        Boolean                   @default(false)
  assignments       DeviceAssignment[]
  assignmentHistory DeviceAssignmentHistory[]

  gpsVerified Boolean @default(false)

  saleItemIDs String[]   @db.ObjectId
  saleItems   SaleItem[] @relation(fields: [saleItemIDs], references: [id])

  creatorId String? @db.ObjectId
  creator   User?   @relation(fields: [creatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([isAssigned])   
  @@map("devices")
}

model Tokens {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  token    String
  duration Int    @default(0)

  tokenReleased Boolean @default(false)

  createdAt DateTime @default(now())

  device   Device? @relation(fields: [deviceId], references: [id])
  deviceId String? @db.ObjectId

  creatorId String? @db.ObjectId
  creator   User?   @relation(fields: [creatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([createdAt, deviceId])
  @@map("token")
}

enum InstallationStatus {
  not_installed
  ready_for_installation
  installed
}

model TokenGenerationFailure {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  saleId       String    @db.ObjectId
  sale         Sales     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  deviceId     String?   @db.ObjectId
  device       Device?   @relation(fields: [deviceId], references: [id])
  serialNumber String?
  reason       String
  errorStack   String?
  retryCount   Int       @default(0)
  maxRetries   Int       @default(3)
  lastRetryAt  DateTime?
  resolvedAt   DateTime?
  resolvedBy   String?   @db.ObjectId
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
