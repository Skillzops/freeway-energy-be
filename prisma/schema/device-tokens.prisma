model Device {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  serialNumber        String  @unique
  key                 String
  startingCode        String?
  count               String?
  timeDivider         String?
  restrictedDigitMode Boolean @default(false)
  hardwareModel       String?
  firmwareVersion     String?

  tokens Tokens[]

  isTokenable Boolean @default(false)

  isUsed Boolean @default(false)

  installationStatus    InstallationStatus @default(not_installed)
  installationLocation  String?
  installationLongitude String?
  installationLatitude  String?

  gpsVerified Boolean @default(false)

  saleItemIDs String[]   @db.ObjectId
  saleItems   SaleItem[] @relation(fields: [saleItemIDs], references: [id])

  creatorId String? @db.ObjectId
  creator   User?   @relation(fields: [creatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("devices")
  @@index([createdAt])
}

model Tokens {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  token    String
  duration Int    @default(0)

  tokenReleased Boolean @default(false)

  createdAt DateTime @default(now())

  device   Device? @relation(fields: [deviceId], references: [id])
  deviceId String? @db.ObjectId

  creatorId String? @db.ObjectId
  creator   User?   @relation(fields: [creatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("token")
}

enum InstallationStatus {
  not_installed
  ready_for_installation
  installed
}
