model Customer {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  firstname        String
  lastname         String
  phone            String
  alternatePhone   String?
  gender           String?
  email            String?
  passportPhotoUrl String?

  addressType         AddressType
  installationAddress String?
  lga                 String?
  state               String?
  location            String?
  longitude           String?
  latitude            String?

  idType     IDType?
  idNumber   String?
  idImageUrl String?

  contractFormImageUrl String?

  approvalStatus ApprovalStatus @default(PENDING)

  isApproved      Boolean   @default(true)
  approvedAt      DateTime?
  approvedBy      String?   @db.ObjectId
  approver        User?     @relation("CustomerApprover", fields: [approvedBy], references: [id])
  rejectedAt      DateTime?
  rejectedBy      String?   @db.ObjectId
  rejecter        User?     @relation("CustomerRejecter", fields: [rejectedBy], references: [id])
  rejectionReason String?

  resubmissionCount  Int                @default(0)
  lastResubmittedAt  DateTime?
  previousRejections RejectionHistory[]

  requiresReview Boolean @default(false)

  status UserStatus @default(active)

  type     CustomerType       @default(lead)
  products CustomerProducts[]

  installerTask  InstallerTask[]
  assignedAgents AgentCustomer[]

  interactions CustomerInteraction[]

  sales Sales[]

  creatorId      String? @db.ObjectId
  creatorDetails User?   @relation(fields: [creatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([createdAt])
  @@index([status])
  @@index([state])
  @@index([lga])
  @@index([firstname])
  @@index([lastname])
  @@index([phone])
  @@index([email])
  @@map("customers")
}

model RejectionHistory {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  rejectedAt DateTime @default(now())
  rejectedBy String   @db.ObjectId
  rejecter   User     @relation("CustomerRejecter", fields: [rejectedBy], references: [id])

  rejectionReason String
  resubmittedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([customerId])
}

model CustomerInteraction {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  interactionType InteractionType @default(NOTE)

  title       String
  description String? @db.String

  interactionDate  DateTime  @default(now())
  nextFollowUpDate DateTime?

  assignedToUserId String? @db.ObjectId
  assignedToUser   User?   @relation("InteractionAssignee", fields: [assignedToUserId], references: [id], onDelete: NoAction)

  createdByUserId String @db.ObjectId
  createdByUser   User   @relation("InteractionCreator", fields: [createdByUserId], references: [id], onDelete: NoAction)

  updatedByUserId String? @db.ObjectId
  updatedByUser   User?   @relation("InteractionUpdater", fields: [updatedByUserId], references: [id], onDelete: NoAction)

  status InteractionStatus @default(OPEN)

  tags String[] // Array of tags for categorization

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  @@index([customerId])
  @@index([createdByUserId])
  @@index([assignedToUserId])
  @@index([status])
  @@index([interactionType])
  @@index([createdAt])
  @@index([customerId, createdAt])
  @@map("customer_interactions")
}

enum InteractionType {
  CALL
  EMAIL
  MEETING
  VISIT
  FOLLOW_UP
  NOTE
  OTHER
}

enum InteractionStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMITTED
}

enum CustomerType {
  lead
  purchase
  residential
}
