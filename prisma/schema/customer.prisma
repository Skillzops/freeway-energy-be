model Customer {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  firstname        String
  lastname         String
  phone            String
  alternatePhone   String?
  gender           String?
  email            String?
  passportPhotoUrl String?

  addressType         AddressType
  installationAddress String?
  lga                 String?
  state               String?
  location            String?
  longitude           String?
  latitude            String?

  idType     IDType?
  idNumber   String?
  idImageUrl String?

  contractFormImageUrl String?

  approvalStatus ApprovalStatus @default(PENDING)

  isApproved      Boolean   @default(true)
  approvedAt      DateTime?
  approvedBy      String?   @db.ObjectId
  approver        User?     @relation("CustomerApprover", fields: [approvedBy], references: [id])
  rejectedAt      DateTime?
  rejectedBy      String?   @db.ObjectId
  rejecter        User?     @relation("CustomerRejecter", fields: [rejectedBy], references: [id])
  rejectionReason String?

  resubmissionCount  Int                @default(0) 
  lastResubmittedAt  DateTime? 
  previousRejections RejectionHistory[]

  requiresReview Boolean @default(false)

  status UserStatus @default(active)

  type     CustomerType       @default(lead)
  products CustomerProducts[]

  installerTask  InstallerTask[]
  assignedAgents AgentCustomer[]

  sales Sales[]

  creatorId      String? @db.ObjectId
  creatorDetails User?   @relation(fields: [creatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("customers")
}

model RejectionHistory {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  rejectedAt DateTime @default(now())
  rejectedBy String   @db.ObjectId
  rejecter   User     @relation("CustomerRejecter", fields: [rejectedBy], references: [id])

  rejectionReason String
  resubmittedAt   DateTime? 

  createdAt DateTime @default(now())

  @@index([customerId])
}

enum ApprovalStatus {
  PENDING 
  APPROVED 
  REJECTED 
  RESUBMITTED 
}

enum CustomerType {
  lead
  purchase
  residential
}
