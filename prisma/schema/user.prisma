model User {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  firstname   String?
  lastname    String?
  username    String?
  password    String
  email       String       @unique
  phone       String?
  location    String?
  addressType AddressType?
  staffId     String?

  longitude String?
  latitude  String?

  emailVerified Boolean @default(false)
  isBlocked     Boolean @default(false)

  status UserStatus @default(active)

  tempToken TempToken[]

  createdApiTokens ApiAuthToken[] @relation("CreatedApiTokens")

  approvedCustomers Customer[]         @relation("CustomerApprover")
  rejectedCustomers Customer[]         @relation("CustomerRejecter")
  rejectionHistory  RejectionHistory[] @relation("CustomerRejecter")

  role         Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       String @db.ObjectId
  createdRoles Role[] @relation("RoleCreator")

  agentDetails Agent?

  warehouseManager          WarehouseManager?
  createdWarehouses         Warehouse[]
  assignedWarehouseManagers WarehouseManager[]         @relation("WarehouseManagerAssigner")
  createdTransferRequests   InventoryTransferRequest[] @relation("InventoryTransferRequestCreator")
  fulfilledTransferRequests InventoryTransferRequest[] @relation("InventoryTransferRequestFulfiller")

  createdProducts         Product[]
  createdCustomers        Customer[]
  createdTokens           Tokens[]
  createdDevices          Device[]
  createdSales            Sales[]
  createdInventoryBatches InventoryBatch[]

  assignmentBatches DeviceAssignmentBatch[]
  assignmentHistory DeviceAssignmentHistory[]

  assignedProducts        AgentProduct[]                 @relation("ProductAssigner")
  assignedCustomers       AgentCustomer[]                @relation("CustomerAssigner")
  customerReassignments   AgentCustomerReassignmentLog[] @relation("CustomerReassigner")
  assignedTasks           InstallerTask[]                @relation("TaskAssigner")
  assignedAgentInstallers AgentInstallerAssignment[]     @relation("AgentInstallerAssigner")

  createdInteractions  CustomerInteraction[] @relation("InteractionCreator")
  updatedInteractions  CustomerInteraction[] @relation("InteractionUpdater")
  assignedInteractions CustomerInteraction[] @relation("InteractionAssignee")

  recordedPayments Payment[] @relation("RecordedPayments")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  lastLogin DateTime?
  auditLogs AuditLog[]

  @@map("users")
}

enum UserStatus {
  active
  inactive
  barred
}

enum AddressType {
  HOME
  WORK
}
