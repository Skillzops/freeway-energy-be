model Agent {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  sales Sales[]

  agentId  Int
  category AgentCategory @default(SALES)

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @unique @db.ObjectId

  installerTask InstallerTask[] @relation("InstallerTasks")
  assignedTasks InstallerTask[] @relation("AssignedTasks")

  deviceAssignments     DeviceAssignment[]
  assignmentHistoryFrom DeviceAssignmentHistory[] @relation("FromAgent")
  assignmentHistoryTo   DeviceAssignmentHistory[] @relation("ToAgent")

  assignedProducts AgentProduct[]

  assignedCustomers   AgentCustomer[]
  assignedInstallers  AgentInstallerAssignment[] @relation("AgentAssignments")
  assignedAsInstaller AgentInstallerAssignment[] @relation("InstallerAssignments")
  walletTransactions  WalletTransaction[]
  supportTickets      SupportTicket[]
  wallet              Wallet?

  customerReassignmentsFrom AgentCustomerReassignmentLog[] @relation("CustomerReassignmentsFrom")
  customerReassignmentsTo   AgentCustomerReassignmentLog[] @relation("CustomerReassignmentsTo")

  ogaranyaAccountNumber String?
  ogaranyaPhone         String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([category])
  @@map("agents")
}

model AgentInstallerAssignment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  installerId String @db.ObjectId
  installer   Agent  @relation("InstallerAssignments", fields: [installerId], references: [id], onDelete: Cascade)

  agentId String @db.ObjectId
  agent   Agent  @relation("AgentAssignments", fields: [agentId], references: [id], onDelete: Cascade)

  assignedBy String @db.ObjectId
  assigner   User   @relation("AgentInstallerAssigner", fields: [assignedBy], references: [id])
}

model AgentProduct {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  agentId String @db.ObjectId
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  productId String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())
  assignedBy String   @db.ObjectId
  assigner   User     @relation("ProductAssigner", fields: [assignedBy], references: [id])

  @@unique([agentId, productId])
  @@index([agentId])
  @@index([productId])
  @@map("agent_products")
}

model AgentCustomer {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  agentId String? @db.ObjectId
  agent   Agent?  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  customerId String?   @db.ObjectId
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())
  assignedBy String   @db.ObjectId
  assigner   User     @relation("CustomerAssigner", fields: [assignedBy], references: [id])

  reassignedFrom     String?   @db.ObjectId // ID of previous agent
  reassignedAt       DateTime?
  reassignmentReason String? // Why was it reassigned?

  @@unique([agentId, customerId])
  @@index([agentId])
  @@index([customerId])
  @@map("agent_customers")
}

model AgentCustomerReassignmentLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  fromAgentId String @db.ObjectId
  fromAgent   Agent  @relation("CustomerReassignmentsFrom", fields: [fromAgentId], references: [id], onDelete: Cascade)

  toAgentId String @db.ObjectId
  toAgent   Agent  @relation("CustomerReassignmentsTo", fields: [toAgentId], references: [id], onDelete: Cascade)

  customerCount Int
  reason        String?
  details       Json? // Store detailed info about what was reassigned

  reassignedBy     String @db.ObjectId
  reassignedByUser User   @relation("CustomerReassigner", fields: [reassignedBy], references: [id], onDelete: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fromAgentId])
  @@index([toAgentId])
  @@index([reassignedBy])
  @@index([createdAt])
  @@map("agent_customer_reassignment_logs")
}

enum AgentCategory {
  SALES
  INSTALLER
  BUSINESS
}
